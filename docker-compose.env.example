# =============================================================================
# 루트(fixie)용 환경 변수 예시
# 사용법: 이 파일을 복사해 fixie 폴더에 ".env" 로 저장한 뒤 값 수정
#
# docker compose 는 "이 파일과 같은 폴더"의 .env 를 읽어 ${변수} 치환에 씁니다.
# Spring OAuth 키는 보통 em-project/spring-backend/.env (compose 의 env_file) 에 둡니다.
# =============================================================================

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRATION=86400000

# AI 서비스(Gemini 등) — docker-compose.yml 의 ai 서비스 GOOGLE_API_KEY 로 전달
GOOGLE_API_KEY=

# (선택) 루트 .env 에만 두고 spring-backend/.env 와 중복하지 않아도 됨
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=

# 브라우저 주소가 127.0.0.1 이면 localhost 와 맞춰 콘솔·아래 값 모두 127.0.0.1 로 통일
# FRONTEND_PUBLIC_URL=http://127.0.0.1:3000
# OAUTH2_GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/login/oauth2/code/google
# OAUTH2_KAKAO_REDIRECT_URI=http://127.0.0.1:3000/login/oauth2/code/kakao
