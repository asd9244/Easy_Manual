# FastAPI AI 백엔드 — 저장소 루트 docker-compose.yml의 Neo4j 기본 계정과 맞춘 예시입니다.
# 사용법: 이 파일을 복사해 `.env`로 저장하세요.

# ──────────────────────────────────────────────────────────
# [팀원 안내] Neo4j를 직접 설치하지 않고, 팀 공유 DB를 사용하려면
# localhost → 192.168.22.54 로 변경하세요.
# 예) NEO4J_URI=bolt://192.168.22.54:7687
# ──────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12341234

# Gemini (채팅 응답 생성) — app/api/routes/chat.py
GOOGLE_API_KEY=

# 임베딩: Ollama 로컬 — 모델 bge-m3, http://127.0.0.1:11434 (별도 설치·실행 필요)
# 필요 시 Ollama 주소를 명시적으로 덮어쓰려면 아래 주석을 해제합니다.
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ──────────────────────────────────────────────────────────
# LangGraph 체크포인트(멀티턴 대화 맥락)용 PostgreSQL 연결 문자열.
# Spring 백엔드와 동일한 pixie DB에 스키마만 추가되는 방식이므로 별도 DB 생성 불필요.
# 로컬(docker-compose): postgresql://postgres:1234@localhost:5432/pixie
# AI 컨테이너에서 호출할 때: postgresql://postgres:1234@postgres:5432/pixie
# 값이 비어 있으면 in-memory MemorySaver로 자동 폴백합니다.
# ──────────────────────────────────────────────────────────
POSTGRES_CHECKPOINT_URL=postgresql://postgres:1234@localhost:5432/pixie
