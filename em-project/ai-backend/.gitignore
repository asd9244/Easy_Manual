# ==========================================
# 1. 가상환경 (Virtual Environments)
# ==========================================
# (주의: 용량이 기가바이트 단위이므로 절대 올리면 안 됨)
venv/
.venv/
env/

# ==========================================
# 2. 보안 및 환경변수 (Security & Env)
# ==========================================
# (주의: API 키, DB 비밀번호 등이 들어있으므로 절대 올리면 안 됨)
.env
.env.*
!.env.example
*.env

# ==========================================
# 3. 로컬 데이터 및 미디어 파일 (Data & Media)
# ==========================================
# (PDF 원본은 깃허브 용량 초과의 주범이므로 무시하지만, 서비스에 필수적인 가공 데이터는 허용합니다)
data/
!data/processed_images/
!data/extracted_texts/
!data/extracted_toc/
*.pdf
# *.png  <-- 특정 폴더 내의 파일은 허용하기 위해 전역 무시 주석 처리하거나 하단에 예외 추가
# 이미지 확장자 무시 규칙은 data/ 외부에서만 작동하도록 유지하되, 위 예외 폴더들은 통과시킵니다.

# ==========================================
# 4. 파이썬 캐시 및 빌드 찌꺼기 (Python Cache)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/

# ==========================================
# 5. IDE 및 OS 찌꺼기 (IDE & OS)
# ==========================================
.idea/
.vscode/
.DS_Store
Thumbs.db

# ==========================================
# 6. 로그 파일 (Logs)
# ==========================================
*.log

# ==========================================
# 7. 코드 모음 파일
# ==========================================
extract_ai_code.py
ai_code_context.txt