# ==========================================
# 1. 가상환경 (Virtual Environments)
# ==========================================
# (주의: 용량이 기가바이트 단위이므로 절대 올리면 안 됨)
venv/
.venv/
env/

# ==========================================
# 2. 보안 및 환경변수 (Security & Env)
# ==========================================
# (주의: API 키, DB 비밀번호 등이 들어있으므로 절대 올리면 안 됨)
.env
.env.*
*.env

# ==========================================
# 3. 로컬 데이터 및 미디어 파일 (Data & Media)
# ==========================================
# (PDF 원본이나 변환된 수백 장의 이미지는 깃허브 용량 초과의 주범입니다)
data/
*.pdf
*.png
*.jpg
*.jpeg

# ==========================================
# 4. 파이썬 캐시 및 빌드 찌꺼기 (Python Cache)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/

# ==========================================
# 5. IDE 및 OS 찌꺼기 (IDE & OS)
# ==========================================
.idea/
.vscode/
.DS_Store
Thumbs.db

# ==========================================
# 6. 로그 파일 (Logs)
# ==========================================
*.log