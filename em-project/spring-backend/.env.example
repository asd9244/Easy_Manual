# Spring Boot — 저장소 루트의 docker-compose.yml(PostgreSQL) 기본값과 맞춘 예시입니다.
# 사용법: 이 파일을 복사해 `.env`로 저장한 뒤 값을 수정하세요. (`.env`는 Git에 포함되지 않습니다.)

# ──────────────────────────────────────────────────────────
# [팀원 안내] DB를 직접 설치하지 않고, 팀 공유 DB를 사용하려면
# localhost → 192.168.22.54 로 변경하세요.
# 예) DB_URL=jdbc:postgresql://192.168.22.54:5432/pixie
# ──────────────────────────────────────────────────────────
# PostgreSQL (루트 docker-compose의 postgres 서비스)
DB_URL=jdbc:postgresql://localhost:5432/pixie
DB_USERNAME=postgres
DB_PASSWORD=1234

# JWT (HS256 — secret은 충분히 긴 임의 문자열 권장, 최소 약 32바이트 이상)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# 만료 시간(밀리초). 예: 86400000 = 24시간
JWT_EXPIRATION=86400000

# OAuth2 — 로컬에서 이메일 로그인만 쓸 경우에도 플레이스홀더가 필요할 수 있습니다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
