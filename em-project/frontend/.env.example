# Vite 프론트엔드 — 복사 후 `.env` / `.env.local` 로 사용하세요.

# vite.config.ts 에서 주입 (선택)
GEMINI_API_KEY=

# AI Studio 등에서 HMR 끄기: DISABLE_HMR=true

# --- API (axios) ---
# 미설정 시 `/api` (Vite dev에서 Spring으로 프록시)
# VITE_API_BASE_URL=https://api.example.com

# --- Vite dev 서버 프록시 대상 (docker-compose 등에서 호스트명 변경 시) ---
# 미설정 시 http://localhost:8080 / http://localhost:8000
# VITE_PROXY_SPRING_ORIGIN=http://spring-backend:8080
# VITE_PROXY_AI_ORIGIN=http://ai-backend:8000
